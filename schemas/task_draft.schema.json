{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentToolTaskDraft",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "effort": {
      "type": ["string", "null"],
      "enum": [null, "medium", "high", "xhigh"]
    },
    "read_scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "write_scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "title",
    "summary",
    "effort",
    "read_scope",
    "write_scope",
    "acceptance"
  ]
}
